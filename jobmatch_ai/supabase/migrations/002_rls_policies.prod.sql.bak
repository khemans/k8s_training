-- ─────────────────────────────────────────────────────────────────
--  JobMatch AI — RLS Policies (PRODUCTION ONLY)
--  Run this in hosted Supabase SQL Editor AFTER 001_initial_schema.sql
--  Do NOT run against the local Docker Postgres — auth schema won't exist
-- ─────────────────────────────────────────────────────────────────

alter table public.users enable row level security;
alter table public.resume_profiles enable row level security;
alter table public.seeker_profiles enable row level security;

create policy "Users can view own record" on public.users
  for select using (supabase_id = auth.uid()::text);

create policy "Users can view own resumes" on public.resume_profiles
  for all using (user_id in (select id from public.users where supabase_id = auth.uid()::text));

create policy "Users can manage own seeker profile" on public.seeker_profiles
  for all using (user_id in (select id from public.users where supabase_id = auth.uid()::text));
